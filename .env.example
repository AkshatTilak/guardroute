# App Configuration
APP_ENV=development
PORT=8000
HOST=0.0.0.0

# Database Configuration
# In production, use postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/guardroute

# Vector Database (Qdrant) Configuration
QDRANT_URL=http://localhost:6333

# External Model Providers
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local Router Configuration
ROUTER_MODEL_PATH=models/Arch-Router-1.5B-Q8_0.gguf

# Telemetry Configuration
OTEL_SERVICE_NAME=guardroute-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
